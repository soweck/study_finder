    "eslint-plugin-import-x": "^4.4.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "neostandard": "^0.13.0",
    "prettier": "^3.9.5",
    "vite": "^7.1.7",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.16",
    "lucide": "^0.555.0",
    "tailwindcss": "^4.1.16"
  }
